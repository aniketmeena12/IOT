{
  "uid": "production-machine-dashboard",
  "title": "Production Machine - Live Pulse Analysis",
  "description": "Real-time monitoring of production machine pulses, intra-series (pulse) gaps, and inter-series (material feed) gaps.",
  "tags": [
    "iot",
    "production-machine",
    "influxdb"
  ],
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": true,
  "panels": [
    {
      "id": 1,
      "title": "Live Pulse Stream",
      "description": "Every pulse from the sensor as it arrives. Gaps between clusters = material feed.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-uid"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "points",
            "pointSize": 5,
            "showPoints": "always",
            "lineWidth": 0,
            "fillOpacity": 0,
            "axisCenteredZero": false,
            "axisLabel": "Pulse"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-uid"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -15m, stop: now())\n  |> filter(fn: (r) => r._measurement == \"spring_pulses\" and r._field == \"pulse\")\n  |> keep(columns: [\"_time\", \"_value\"])"
        }
      ]
    },
    {
      "id": 2,
      "title": "Intra-Series Gap (Time Between Pulses)",
      "description": "Time difference between consecutive pulses within each product. Spikes indicate series boundaries (filtered out in averages).",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-uid"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "auto"
          },
          "unit": "ms",
          "displayName": "Gap (ms)"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-uid"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -15m, stop: now())\n  |> filter(fn: (r) => r._measurement == \"spring_pulses\" and r._field == \"pulse\")\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> sort(columns: [\"_time\"])\n  |> elapsed(unit: 1ms)\n  |> drop(columns: [\"_value\"])\n  |> rename(columns: {elapsed: \"_value\"})\n  |> filter(fn: (r) => r._value < 200)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Inter-Series Gap (Material Feed Time)",
      "description": "Time between the last pulse of one product and the first pulse of the next product.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-uid"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "always"
          },
          "unit": "ms",
          "displayName": "Gap (ms)"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-uid"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -15m, stop: now())\n  |> filter(fn: (r) => r._measurement == \"spring_pulses\" and r._field == \"pulse\")\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> sort(columns: [\"_time\"])\n  |> elapsed(unit: 1ms)\n  |> drop(columns: [\"_value\"])\n  |> rename(columns: {elapsed: \"_value\"})\n  |> filter(fn: (r) => r._value >= 200)"
        }
      ]
    },
    {
      "id": 4,
      "title": "Average Intra-Series Gap (last 5 min)",
      "description": "Rolling average of the time between consecutive pulses within products.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-uid"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 80,
                "color": "yellow"
              },
              {
                "value": 120,
                "color": "red"
              }
            ]
          },
          "unit": "ms",
          "displayName": "Avg Pulse Gap"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },

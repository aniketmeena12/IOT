          "query": "from(bucket: \"spring_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"spring_pulses\" and r._field == \"pulse\")\n  |> keep(columns: [\"_time\", \"_value\"])\n  |> sort(columns: [\"_time\"])\n  |> elapsed(unit: 1ms)\n  |> drop(columns: [\"_value\"])\n  |> rename(columns: {elapsed: \"_value\"})\n  |> filter(fn: (r) => r._value < 200)\n  |> mean()"
        }

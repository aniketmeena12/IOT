{
  "uid": "heating-simulation-dashboard",
  "title": "Heating Simulation - Smart Sensor System",
  "description": "Real-time Smart Heating controller metrics from heating_system_smart_final.py",
  "tags": [
    "iot",
    "heating",
    "simulation",
    "influxdb",
    "corrugated"
  ],
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Sensor Temp vs Auto Target",
      "description": "Live process temperature from thermocouple vs auto-computed PID setpoint",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 160
              },
              {
                "color": "red",
                "value": 175
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -15m, stop: now())\n  |> filter(fn: (r) => r._measurement == \"spring_heating\")\n  |> filter(fn: (r) => r._field == \"sensor_temp\" or r._field == \"target\")\n  |> aggregateWindow(every: 10s, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Heater Power (%)",
      "description": "PID output \u2014 heater power. Drops to 0% immediately on sensor FAULT.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -15m, stop: now())\n  |> filter(fn: (r) => r._measurement == \"spring_heating\" and r._field == \"power\")\n  |> aggregateWindow(every: 10s, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Ambient Temp & Humidity",
      "description": "Environmental sensor readings used by the Auto Target Setter",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "humidity"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ambient"
            },
            "properties": [
              {
                "id": "unit",
                "value": "celsius"
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -15m, stop: now())\n  |> filter(fn: (r) => r._measurement == \"spring_heating\")\n  |> filter(fn: (r) => r._field == \"ambient\" or r._field == \"humidity\")\n  |> aggregateWindow(every: 10s, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Current Error (\u00b0C)",
      "description": "Target \u2212 Sensor temp. Near 0 = stable.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value",
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"spring_heating\" and r._field == \"error\")\n  |> last()"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "System Fault",
      "description": "0 = Normal  |  1 = SENSOR FAULT (heater cut to 0%)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 14
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OK",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "FAULT",
                  "color": "red"
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value",
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"spring_heating\" and r._field == \"system_fault\")\n  |> last()"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Alarms",
      "description": "Cumulative count of SENSOR FAULT alarms raised since startup",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value",
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"spring_heating\" and r._field == \"alarm_count\")\n  |> last()"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "PID Terms (P / I / D)",
      "description": "P=instant reaction  I=accumulated error  D=rate of change (braking)",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -15m, stop: now())\n  |> filter(fn: (r) => r._measurement == \"spring_heating\")\n  |> filter(fn: (r) => r._field == \"p_term\" or r._field == \"i_term\" or r._field == \"d_term\")\n  |> aggregateWindow(every: 10s, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Machine State",
      "description": "Current operating state: HEATING / STABLE / COOLING / SENSOR FAULT",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 19
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "last"
          ]
        },
        "textMode": "value",
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"spring_heating\" and r._field == \"state\")\n  |> last()"
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Sensor Modes (REAL / SIMULATION / FAULT)",
      "description": "Shows live data source for each sensor \u2014 REAL=hardware, SIMULATION=physics model, FAULT=alarm",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 19
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "string"
        },
        "overrides": []
      },
      "options": {
        "sortBy": [],
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"spring_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"spring_heating\")\n  |> filter(fn: (r) => r._field == \"temp_mode\" or r._field == \"hum_mode\" or r._field == \"amb_mode\")\n  |> last()\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> keep(columns: [\"_time\", \"temp_mode\", \"hum_mode\", \"amb_mode\"])"
        }
      ]
    }
  ],
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB datasource",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ]
}